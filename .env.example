# ======================================
# Supabase — Database & Auth
# ======================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ======================================
# Telegram Bot
# ======================================
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...

# ======================================
# Google Gemini AI
# ======================================
GEMINI_API_KEY=AIzaSy...

# ======================================
# Phajay Payment Gateway — Test vs Production
# ======================================
# test | production — ກຳນົດວ່າໃຊ້ຊຸດ key ໃດ (ບໍ່ເດົາເອງຈາກຮູບແບບ key)
PHAJAY_MODE=test

# --- API key (secretKey / Bearer) ຕາມໂໝດ ---
# Test: ວາງ Test Key ຈາກ Phajay dashboard (ອາດເປັນຮູບແບບ bcrypt $2a$10$... ຫຼື string ຕາມທີ່ Phajay ໃຫ້)
PHAJAY_SECRET_KEY_TEST=
# Production (ຫຼັງ KYC): Production key
PHAJAY_SECRET_KEY_PRODUCTION=
# Fallback: ໃຊ້ຄ່າດຽວກັນທັງ test ແລະ prod (backward compatible)
PHAJAY_SECRET_KEY=

# --- Webhook HMAC ສຳລັບ x-phajay-signature (ຕ້ອງກົງກັບຄ່າ Test/Production Key ໃນແຜງ Phajay — ບໍ່ດັ່ງນັ້ນຊຳລະສຳເລັດແຕ່ DB ບໍ່ອັບເດດ) ---
PHAJAY_WEBHOOK_SECRET_TEST=
PHAJAY_WEBHOOK_SECRET_PRODUCTION=
PHAJAY_WEBHOOK_SECRET=

# --- API base URL (ປົກກະຕິໃຊ້ຄ່າ default ໃນໂຄ້ດ) ---
PHAJAY_API_URL=https://payment-gateway.phajay.co/v1/api
# PHAJAY_API_URL_TEST=
# PHAJAY_API_URL_PRODUCTION=

PHAJAY_MERCHANT_ID=

# --- ທົດສອບ webhook ບໍ່ມີ signature (ສະເພາະ test, ບໍ່ໃຊ້ໃນ production) ---
# PHAJAY_ALLOW_UNSIGNED_WEBHOOKS=true

# ======================================
# App Configuration
# ======================================
APP_URL=https://your-app.pages.dev
NEXT_PUBLIC_APP_URL=https://your-app.pages.dev
ADMIN_TELEGRAM_ID=123456789
WEBHOOK_SECRET=generate_random_secret_here_min_32_chars

# ======================================
# Subscription Config (ຝັ່ງລະບົບເຮົາ — ບໍ່ແມ່ນ Phajay)
# ======================================
# PHAJAY_MODE=test ໃຊ້ຈຳນວນນີ້ສຳລັບບິນ QR (ບໍ່ເກີນ limit ທົດລອງ — ຕົວຢ່າງ 500 ກີບ)
SUBSCRIPTION_TEST_AMOUNT=500
# PHAJAY_MODE=production: ລາຄາຕໍ່ 1 ເດືອນ (ກີບ); ແຜນ 6m = ×5, 12m = ×10 ຂອງລາຄານີ້ (default ໃນໂຄ້ດ 50000)
SUBSCRIPTION_PRICE_LAK=50000
SUBSCRIPTION_DURATION_DAYS=30
# ຊ່ວງຫຼັງສ້າງ QR ທີ່ຄືນ QR ເກົ່າຈາກ DB ແທນການເອີ້ນ Phajay ຊ້ຳ (ວິນາທີ, default 120)
SUBSCRIPTION_QR_COOLDOWN_SECONDS=120
